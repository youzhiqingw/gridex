<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Gridex.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Gridex"
    Title="Gridex">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Frame x:Name="ContentFrame" />

        <!-- Startup update-check overlay. Shown before the ContentFrame
             navigates so the main app never appears while the network
             check is in flight. Hidden by MainWindow once the check
             completes (with or without an update). -->
        <Grid x:Name="UpdateCheckOverlay"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="16">
                <ProgressRing IsActive="True" Width="48" Height="48" />
                <TextBlock x:Name="UpdateCheckStatusText"
                           Text="正在检查更新..."
                           HorizontalAlignment="Center"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
