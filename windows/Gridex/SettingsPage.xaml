<Page
    x:Class="Gridex.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Gridex"
    Background="Transparent">

    <ScrollViewer Padding="32,24">
        <StackPanel MaxWidth="700" Spacing="24">

            <!-- Header with Back button -->
            <StackPanel Spacing="8">
                <Button x:Name="BackBtn"
                        Background="Transparent" BorderThickness="0"
                        Padding="8,4" HorizontalAlignment="Left"
                        ToolTipService.ToolTip="返回">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72B;" FontSize="14" />
                        <TextBlock Text="返回" FontSize="13" />
                    </StackPanel>
                </Button>
                <TextBlock Text="设置" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="配置 Gridex 偏好"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Appearance -->
            <StackPanel Spacing="12">
                <TextBlock Text="外观" FontSize="16" FontWeight="SemiBold" />

                <Grid Padding="16"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      CornerRadius="8"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                        <TextBlock Text="主题" FontSize="14" />
                        <TextBlock Text="选择浅色、深色或系统默认"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <ComboBox x:Name="ThemeCombo" Grid.Row="0" Grid.Column="1"
                              MinWidth="140"
                              SelectedIndex="0"
>
                        <ComboBoxItem Content="系统默认" />
                        <ComboBoxItem Content="浅色" />
                        <ComboBoxItem Content="深色" />
                    </ComboBox>

                    <Border Grid.Row="1" Grid.ColumnSpan="2"
                            Height="1" Margin="0,12,0,0"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                            Visibility="Collapsed" />
                </Grid>
            </StackPanel>

            <!-- AI Configuration -->
            <StackPanel Spacing="12">
                <TextBlock Text="AI 助手" FontSize="16" FontWeight="SemiBold" />

                <Grid Padding="16"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      CornerRadius="8"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="提供方" FontSize="14" />
                            <!-- Order MUST match DBModels::AiProvider enum
                                 in Models/AiService.h — never reorder, only
                                 append at the end (the index is persisted
                                 in settings as aiProviderIndex). -->
                            <ComboBox x:Name="AiProviderCombo" MinWidth="200"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Anthropic（Claude）" />
                                <ComboBoxItem Content="OpenAI（GPT）" />
                                <ComboBoxItem Content="Ollama（本地）" />
                                <ComboBoxItem Content="Google Gemini" />
                                <ComboBoxItem Content="OpenRouter" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Anthropic 基础地址" FontSize="14" />
                            <TextBox x:Name="AnthropicEndpointBox"
                                     PlaceholderText="https://api.anthropic.com"
                                     Width="400"
                                     HorizontalAlignment="Left" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="OpenAI 基础地址" FontSize="14" />
                            <TextBox x:Name="OpenAIEndpointBox"
                                     PlaceholderText="https://api.openai.com"
                                     Width="400"
                                     HorizontalAlignment="Left" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="API 密钥" FontSize="14" />
                            <PasswordBox x:Name="ApiKeyBox"
                                         PlaceholderText="输入你的 API 密钥..."
                                         Width="400"
                                         HorizontalAlignment="Left" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="模型" FontSize="14" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <!-- Editable ComboBox: pick from the
                                     list fetched via Refresh, or type a
                                     custom model name (custom domains,
                                     OpenAI-compatible proxies, etc.). -->
                                <ComboBox x:Name="ModelBox"
                                          IsEditable="true"
                                          PlaceholderText="选择或输入模型…"
                                          Width="400" />
                                <Button x:Name="RefreshModelsBtn"
                                        ToolTipService.ToolTip="从所选提供方获取可用模型">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE72C;" FontSize="12" />
                                        <TextBlock Text="刷新" FontSize="12" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <TextBlock x:Name="ModelFetchStatusText"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       Visibility="Collapsed" />
                        </StackPanel>

                        <StackPanel x:Name="OllamaEndpointPanel" Spacing="4">
                            <TextBlock Text="Ollama 端点" FontSize="14" />
                            <TextBox x:Name="OllamaEndpointBox"
                                     PlaceholderText="http://localhost:11434"
                                     Width="400"
                                     HorizontalAlignment="Left" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Editor -->
            <StackPanel Spacing="12">
                <TextBlock Text="编辑器" FontSize="16" FontWeight="SemiBold" />

                <Grid Padding="16"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      CornerRadius="8"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="字体大小" FontSize="14" />
                            <NumberBox x:Name="EditorFontSizeBox" Value="13"
                                       Minimum="8" Maximum="24"
                                       SpinButtonPlacementMode="Inline"
                                       Width="120"
                                       HorizontalAlignment="Left" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="默认行数上限" FontSize="14" />
                            <NumberBox x:Name="RowLimitBox" Value="100"
                                       Minimum="10" Maximum="10000"
                                       SpinButtonPlacementMode="Inline"
                                       Width="160"
                                       HorizontalAlignment="Left" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Updates -->
            <StackPanel Spacing="12">
                <TextBlock Text="更新" FontSize="16" FontWeight="SemiBold" />

                <Grid Padding="16"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      CornerRadius="8"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="检查更新" FontSize="14" />
                        <TextBlock x:Name="UpdateStatusText"
                                   Text="点击按钮进行检查。"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <Button x:Name="CheckUpdateButton"
                            Grid.Column="1"
                            Content="立即检查"
                            Padding="16,6"
                            VerticalAlignment="Center" />
                </Grid>
            </StackPanel>

            <!-- Keyboard Shortcuts — populated in SettingsPage.cpp from
                 DBModels::BuildShortcutsView() so this section and the
                 Ctrl+/ dialog stay visually identical. -->
            <StackPanel Spacing="12">
                <TextBlock Text="键盘快捷键" FontSize="16" FontWeight="SemiBold" />
                <Border Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="在应用中任意位置按 Ctrl+/ 或 F1 打开此参考。" />
                        <ContentControl x:Name="ShortcutsHost"
                                        HorizontalContentAlignment="Stretch" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- About -->
            <StackPanel Spacing="8">
                <TextBlock Text="关于" FontSize="16" FontWeight="SemiBold" />
                <TextBlock FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="Gridex" FontWeight="SemiBold" />
                    <Run Text=" — AI 原生数据库 IDE" />
                </TextBlock>
                <TextBlock x:Name="VersionText"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />

                <!-- Open Source attribution -->
                <TextBlock FontSize="11"
                           Margin="0,8,0,0"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           TextWrapping="Wrap">
                    <Run Text="ER 图渲染由 " />
                    <Run Text="D2" FontWeight="SemiBold" />
                    <Run Text=" (MPL-2.0) © Terrastruct, Inc." />
                    <LineBreak />
                    <Run Text="数据库连接通过 libpq、libmariadb、sqlite3。界面使用 WinUI 3 + WebView2。" />
                </TextBlock>

                <Button x:Name="ViewLicensesButton"
                        Content="查看开源许可证..."
                        Margin="0,8,0,0"
                        Padding="12,4"
                        FontSize="12" />
            </StackPanel>

            <!-- Save All — applies to every section above -->
            <Border Margin="0,8,0,32"
                    Padding="0,16,0,0"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" Spacing="12"
                            HorizontalAlignment="Right">
                    <TextBlock x:Name="SaveStatusText"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <Button x:Name="SaveAiButton"
                            Content="保存全部设置"
                            Padding="20,8"
                            Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
